# Host port mapped to container port 3000.
APP_PORT=3000

# Public site URL. Use your real domain in production, for example:
# NEXT_PUBLIC_SITE_URL=https://blog.example.com
# SITE_URL=https://blog.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# GitHub repository that stores the blog content.
NEXT_PUBLIC_GITHUB_OWNER=yysuni
NEXT_PUBLIC_GITHUB_REPO=2025-blog-public
NEXT_PUBLIC_GITHUB_BRANCH=main

# GitHub App ID from Developer settings.
NEXT_PUBLIC_GITHUB_APP_ID=-

# Must match the key used by the frontend when encrypting GitHub App private keys.
NEXT_PUBLIC_GITHUB_ENCRYPT_KEY=wudishiduomejimo

# Optional blog slug protection key.
BLOG_SLUG_KEY=
